# Copy to .env and fill in real values. Never commit .env.
SECRET_KEY=replace-with-a-long-random-string
# Never True in a deployed environment: DEBUG exposes tracebacks with settings
# and turns on Django's static media handler (no access control).
# On Railway (or any host that sets RAILWAY_ENVIRONMENT), leave the DEBUG env
# var False or unset — settings.py refuses to boot with DEBUG=True there, and
# the production HTTPS/HSTS/secure-cookie hardening only switches on when
# DEBUG is False. Local dev keeps DEBUG=True.
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgres://postgres:your-password@localhost:5432/mv_alaska
CORS_ALLOWED_ORIGINS=http://localhost:5173

SSLCOMMERZ_STORE_ID=your-store-id
SSLCOMMERZ_STORE_PASSWORD=your-store-password
SSLCOMMERZ_IS_SANDBOX=True
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
BOOKING_HOLD_MINUTES=30
# Authority helpline numbers shown on the guide report & customer invoice
# (comma-separated)
AUTHORITY_PHONES=01712-823482,01831-694307,01342-919795
# Gateway session lifetime: reconcile_pending_payments closes unattempted
# PENDING payments older than this (after confirming with the gateway)
PAYMENT_SESSION_MINUTES=30
# Days before the balance deadline that the reminder email goes out
BALANCE_DUE_REMINDER_DAYS=2
# Trusted proxy hop count for DRF throttling (Railway: 1; 0 if no proxy)
DRF_NUM_PROXIES=1

# Cloudinary — PUBLIC imagery (hero/layout/room photos). Permanent CDN URLs.
# From the Cloudinary dashboard: cloudinary://<api_key>:<api_secret>@<cloud_name>
# Optional: unset falls back to B2 (presigned URLs) or the local filesystem.
CLOUDINARY_URL=cloudinary://your-api-key:your-api-secret@your-cloud-name

# Backblaze B2 object storage (S3-compatible) — invoice PDFs (customer PII),
# and the fallback for imagery when Cloudinary is unset. Optional: leave unset
# to store media on the local filesystem (fine for dev; NOT for cloud hosts,
# whose ephemeral disks wipe uploads and invoice PDFs on every redeploy).
# Both buckets must be PRIVATE — files are served via presigned URLs.
# Endpoint + keys come from Backblaze: Buckets page and Application Keys page.
B2_S3_ENDPOINT_URL=https://s3.your-region.backblazeb2.com
B2_ACCESS_KEY_ID=your-b2-keyID
B2_SECRET_ACCESS_KEY=your-b2-applicationKey
B2_MEDIA_BUCKET=your-media-bucket-name
B2_INVOICE_BUCKET=your-invoice-bucket-name

# console backend for dev; use django.core.mail.backends.smtp.EmailBackend in production
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=MV Alaska <your-email@gmail.com>
